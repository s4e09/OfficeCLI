{
  "$schema": "../_schema.json",
  "format": "pptx",
  "element": "shape",
  "operations": {
    "add": true,
    "set": true,
    "get": true,
    "query": true,
    "remove": true
  },
  "paths": {
    "stable": ["/slide[N]/shape[@id=ID]"],
    "positional": ["/slide[N]/shape[N]"]
  },
  "properties": {
    "text": {
      "type": "string",
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop text=\"Hello\""],
      "readback": "plain text content of the shape",
      "enforcement": "strict"
    },
    "fill": {
      "type": "color",
      "aliases": ["background"],
      "add": true,
      "set": true,
      "get": true,
      "examples": [
        "--prop fill=FF0000",
        "--prop fill=#FF0000",
        "--prop fill=red",
        "--prop fill=accent1"
      ],
      "readback": "#RRGGBB (uppercase) or scheme color name (e.g. accent1)",
      "enforcement": "strict"
    },
    "color": {
      "type": "color",
      "description": "text color",
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop color=0000FF"],
      "readback": "#RRGGBB (uppercase)",
      "enforcement": "strict"
    },
    "size": {
      "type": "font-size",
      "description": "font size",
      "aliases": ["fontSize", "fontsize"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop size=14", "--prop size=14pt", "--prop size=10.5pt"],
      "readback": "unit-qualified string, e.g. \"14pt\"",
      "enforcement": "strict"
    },
    "bold": {
      "type": "bool",
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop bold=true"],
      "readback": "true | false",
      "enforcement": "strict"
    },
    "italic": {
      "type": "bool",
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop italic=true"],
      "readback": "true | false",
      "enforcement": "strict"
    },
    "align": {
      "type": "enum",
      "values": ["left", "center", "right", "justify"],
      "description": "text horizontal alignment",
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop align=center"],
      "readback": "one of: left | center | right | justify",
      "enforcement": "strict"
    },
    "x": {
      "type": "length",
      "description": "horizontal position of shape",
      "aliases": ["left"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop x=2cm", "--prop x=1in", "--prop x=72pt"],
      "readback": "length in cm (e.g. \"2cm\")",
      "enforcement": "strict"
    },
    "y": {
      "type": "length",
      "description": "vertical position of shape",
      "aliases": ["top"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop y=3cm"],
      "readback": "length in cm (e.g. \"3cm\")",
      "enforcement": "strict"
    },
    "width": {
      "type": "length",
      "aliases": ["w"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop width=5cm"],
      "readback": "length in cm",
      "enforcement": "strict"
    },
    "height": {
      "type": "length",
      "aliases": ["h"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop height=3cm"],
      "readback": "length in cm",
      "enforcement": "strict"
    },
    "rotation": {
      "type": "number",
      "description": "rotation in degrees",
      "aliases": ["rotate"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop rotation=45"],
      "readback": "degrees as number (e.g. 45)",
      "enforcement": "strict"
    },
    "opacity": {
      "type": "number",
      "description": "fill opacity (0.0 - 1.0). Requires a fill to attach to — opacity alone (without fill/gradient/pattern) has no effect in OOXML.",
      "requires": ["fill"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop opacity=0.5 --prop fill=FF0000"],
      "readback": "number in [0, 1]",
      "enforcement": "strict"
    },
    "name": {
      "type": "string",
      "description": "shape name (identifier, not display text)",
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop name=MyShape"],
      "readback": "plain string",
      "enforcement": "strict"
    },
    "geometry": {
      "type": "string",
      "description": "Preset shape geometry (default: rect).",
      "aliases": ["preset", "shape"],
      "values": ["rect", "roundRect", "ellipse", "triangle", "diamond", "parallelogram", "rightArrow", "star5"],
      "add": true,
      "set": true,
      "get": true,
      "examples": ["--prop geometry=ellipse", "--prop preset=roundRect"],
      "readback": "preset name (e.g. \"ellipse\", \"roundRect\")",
      "enforcement": "strict"
    },
    "font": {
      "type": "string",
      "description": "default font family for shape text.",
      "add": true, "set": true, "get": true,
      "examples": ["--prop font=Arial"],
      "readback": "font name",
      "enforcement": "report"
    },
    "underline": {
      "type": "enum",
      "description": "underline style for shape text.",
      "values": ["single", "double", "dotted", "dash", "wave", "none"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop underline=single"],
      "readback": "underline style",
      "enforcement": "report"
    },
    "strike": {
      "type": "bool",
      "description": "strikethrough on shape text.",
      "aliases": ["strikethrough"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop strike=true"],
      "readback": "true | false",
      "enforcement": "report"
    },
    "valign": {
      "type": "enum",
      "description": "vertical alignment of text within shape.",
      "values": ["top", "middle", "bottom", "ctr"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop valign=middle"],
      "readback": "vertical alignment",
      "enforcement": "report"
    },
    "margin": {
      "type": "length",
      "description": "uniform internal padding (text inset) for shape body.",
      "add": true, "set": true, "get": false,
      "examples": ["--prop margin=0.1in"],
      "readback": "n/a",
      "enforcement": "report"
    },
    "autofit": {
      "type": "enum",
      "description": "auto-fit mode for shape text body.",
      "values": ["none", "normal", "shape", "noAutofit", "spAutoFit"],
      "add": true, "set": true, "get": false,
      "examples": ["--prop autofit=shape"],
      "readback": "n/a",
      "enforcement": "report"
    },
    "lineSpacing": {
      "type": "string",
      "description": "line spacing for shape paragraphs (multiplier or pt).",
      "aliases": ["linespacing"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop lineSpacing=1.5x"],
      "readback": "1.5x or 18pt",
      "enforcement": "report"
    },
    "spaceBefore": {
      "type": "length",
      "aliases": ["spacebefore"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop spaceBefore=6pt"],
      "readback": "unit-qualified pt",
      "enforcement": "report"
    },
    "spaceAfter": {
      "type": "length",
      "aliases": ["spaceafter"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop spaceAfter=6pt"],
      "readback": "unit-qualified pt",
      "enforcement": "report"
    },
    "gradient": {
      "type": "string",
      "description": "gradient fill spec (e.g. 'FF0000;0000FF' linear or 'FF0000:0,0000FF:100').",
      "add": true, "set": true, "get": false,
      "examples": ["--prop gradient=\"FF0000;0000FF\""],
      "readback": "n/a",
      "enforcement": "report"
    },
    "pattern": {
      "type": "string",
      "description": "pattern fill (preset;fg;bg).",
      "add": true, "set": true, "get": false,
      "examples": ["--prop pattern=\"diagBrick;FF0000;FFFFFF\""],
      "readback": "n/a",
      "enforcement": "report"
    },
    "line": {
      "type": "color",
      "description": "outline (border) color.",
      "aliases": ["linecolor", "lineColor", "border"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop line=000000"],
      "readback": "#RRGGBB",
      "enforcement": "report"
    },
    "linewidth": {
      "type": "length",
      "description": "outline width.",
      "aliases": ["lineWidth"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop linewidth=1pt"],
      "readback": "unit-qualified",
      "enforcement": "report"
    },
    "list": {
      "type": "string",
      "description": "list style for shape paragraphs (bullet|ordered|none).",
      "aliases": ["liststyle"],
      "add": true, "set": true, "get": false,
      "examples": ["--prop list=bullet"],
      "readback": "n/a",
      "enforcement": "report"
    },
    "link": {
      "type": "string",
      "description": "hyperlink URL or anchor for shape click action.",
      "add": true, "set": true, "get": false,
      "examples": ["--prop link=https://example.com"],
      "readback": "n/a",
      "enforcement": "report"
    },
    "tooltip": {
      "type": "string",
      "description": "tooltip / screen-tip text for hyperlink.",
      "add": true, "set": true, "get": false,
      "examples": ["--prop tooltip=\"click here\""],
      "readback": "n/a",
      "enforcement": "report"
    },
    "animation": {
      "type": "string",
      "description": "animation effect spec.",
      "aliases": ["animate"],
      "add": true, "set": true, "get": false,
      "examples": ["--prop animation=fade"],
      "readback": "n/a",
      "enforcement": "report"
    }
  }
}
