{
  "$schema": "../_schema.json",
  "format": "pptx",
  "element": "picture",
  "parent": "slide",
  "operations": {
    "add": true,
    "set": true,
    "get": true,
    "query": true,
    "remove": true
  },
  "paths": {
    "positional": ["/slide[N]/picture[M]"]
  },
  "note": "Aliases: image, img. 'src' (alias 'path') required. Source resolved by ImageSource — file path, URL, data-URI, raw bytes.",
  "properties": {
    "src": {
      "type": "string",
      "aliases": ["path"],
      "add": true, "set": true, "get": true,
      "examples": ["--prop src=/path/to/image.png"],
      "readback": "resolved image URL or rel id",
      "enforcement": "report"
    },
    "x": {
      "type": "length",
      "add": true, "set": true, "get": true,
      "examples": ["--prop x=1in"],
      "readback": "length in cm (e.g. \"2cm\")",
      "enforcement": "report"
    },
    "y": {
      "type": "length",
      "add": true, "set": true, "get": true,
      "examples": ["--prop y=1in"],
      "readback": "length in cm (e.g. \"2cm\")",
      "enforcement": "report"
    },
    "width": {
      "type": "length",
      "description": "EMU-parseable. Defaults to 6in if omitted.",
      "add": true, "set": true, "get": true,
      "examples": ["--prop width=3in"],
      "readback": "length in cm (e.g. \"2cm\")",
      "enforcement": "report"
    },
    "height": {
      "type": "length",
      "description": "EMU-parseable. Defaults to 4in if omitted.",
      "add": true, "set": true, "get": true,
      "examples": ["--prop height=2in"],
      "readback": "length in cm (e.g. \"2cm\")",
      "enforcement": "report"
    },
    "crop": {
      "type": "string",
      "description": "Crop in percent (0-100). 1 value = symmetric, 2 values = vertical,horizontal, 4 values = left,top,right,bottom.",
      "add": true, "set": true,
      "examples": ["--prop crop=10", "--prop crop=5,10", "--prop crop=10,5,10,5"],
      "enforcement": "report"
    },
    "cropLeft": {
      "type": "string",
      "description": "Crop from left edge as percent (0-100). Aliases: cropleft.",
      "aliases": ["cropleft"],
      "add": true, "set": true,
      "examples": ["--prop cropLeft=10"],
      "enforcement": "report"
    },
    "cropRight": {
      "type": "string",
      "description": "Crop from right edge as percent (0-100). Aliases: cropright.",
      "aliases": ["cropright"],
      "add": true, "set": true,
      "examples": ["--prop cropRight=10"],
      "enforcement": "report"
    },
    "cropTop": {
      "type": "string",
      "description": "Crop from top edge as percent (0-100). Aliases: croptop.",
      "aliases": ["croptop"],
      "add": true, "set": true,
      "examples": ["--prop cropTop=10"],
      "enforcement": "report"
    },
    "cropBottom": {
      "type": "string",
      "description": "Crop from bottom edge as percent (0-100). Aliases: cropbottom.",
      "aliases": ["cropbottom"],
      "add": true, "set": true,
      "examples": ["--prop cropBottom=10"],
      "enforcement": "report"
    }
  }
}
